---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Brutto-Netto-Rechner | Gehaltsrechner für Deutschland',
  description = 'Berechnen Sie Ihr Nettogehalt aus dem Bruttoeinkommen. Inklusive Lohnsteuer, Solidaritätszuschlag und allen Sozialversicherungsbeiträgen.',
} = Astro.props;

const siteUrl = 'https://davidleimroth.github.io/steuerrechner';
---

<!doctype html>
<html lang="de" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/steuerrechner/favicon.svg" />
    <link rel="icon" href="/steuerrechner/favicon.ico" sizes="32x32" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={siteUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="Brutto-Netto-Rechner" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <title>{title}</title>

    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <!-- Prevent flash of wrong language -->
    <script is:inline>
      (function() {
        const locale = localStorage.getItem('locale');
        if (locale === 'en' || locale === 'de' || locale === 'es') {
          document.documentElement.setAttribute('lang', locale);
        }
      })();
    </script>
  </head>
  <body class="min-h-screen bg-base-200">
    <slot />
  </body>
</html>
